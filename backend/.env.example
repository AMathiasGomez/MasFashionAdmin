NODE_ENV=development
PORT=3000
API_PREFIX=/api

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=clothing_admin
DB_CONNECTION_LIMIT=10

JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=8h
JWT_ISSUER=clothing-admin-api

CORS_ORIGIN=http://localhost:4200

GOOGLE_CLIENT_ID=

# SMTP para envio de correos (ej. Gmail: smtp.gmail.com, puerto 587, usar una "contrasena de aplicacion")
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Exportacion automatica programada de reportes
REPORT_SCHEDULE_ENABLED=false
REPORT_SCHEDULE_CRON=0 8 * * 1
REPORT_SCHEDULE_TYPE=sales
REPORT_SCHEDULE_FORMAT=xlsx
REPORT_SCHEDULE_RECIPIENTS=

